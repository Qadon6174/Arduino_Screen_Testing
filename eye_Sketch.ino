int timesBlinked = 0;
void setup(){

  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("SSD1306 allocation failed"));
    for(;;); // Don't proceed, loop forever
  }
	//Set up text display
	display.setTextSize(1);
	display.setTextColor(SSD1306_WHITE);

}

void loop(){
	//Clears display
		display.clearDisplay();
		//Sets random event (face);
		int nextEvent = int(random(1,100));
		if (nextEvent < 30){
			goSleep();
		}
		else if(nextEvent < 50){
			blink();
		}
		else{
			default_face();
		}
  delay(1000);
}

//Function to show at bottom of screen how many times the blink command has occured
void showTimesBlinked(){
	//display.setCursor(0,48);
  //display.print("Times I've Blinked:\n"+String(timesBlinked));
}

//Basic default smile face
void default_face(){
  //Left Eye
  display.drawBitmap(
	LEFT_EYE_DISTANCE_W,
	EYE_DISTANCE_H,
  Bitmap_allEye[3],
	EYE_WIDTH,EYE_HEIGHT,1
  );
  //Right Eye
  display.drawBitmap(
	RIGHT_EYE_DISTANCE_W,
	EYE_DISTANCE_H,
  Bitmap_allEye[3],
	EYE_WIDTH,
	EYE_HEIGHT,
	1
  );
	//Mouth
	display.drawBitmap(MOUTH_DISTANCE_X,
	MOUTH_DISTANCE_Y,
  Bitmap_allMouth[1],
	MOUTH_WIDTH,
	MOUTH_HEIGHT,
	1
	);
	//Display
	display.display();
	delay(1000);
}

void blink(){
	//For eyes closing
  for (int i = 3; i <= 7;i++){
		display.clearDisplay();
		showTimesBlinked();
		//Left Eye
		display.drawBitmap(
			LEFT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
			Bitmap_allEye[i],
			EYE_WIDTH,EYE_HEIGHT,
			1
		);
		//Right Eye
		display.drawBitmap(
			RIGHT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
			Bitmap_allEye[i],
			EYE_WIDTH,
			EYE_HEIGHT,
			1
		);
		//Mouth
		display.drawBitmap(
			MOUTH_DISTANCE_X,
			MOUTH_DISTANCE_Y,
			Bitmap_Mouth_1,
			MOUTH_WIDTH,
			MOUTH_HEIGHT,
			1);
		display.display();
		delay(84);
  }
	//Small delay for smooth animation
  delay(84);
	//Increase blink counter
	timesBlinked++;
	//For eyes opening
  for (int i = 7; i > 2;i--){
		display.clearDisplay();
		showTimesBlinked();
		display.drawBitmap(
			LEFT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
			Bitmap_allEye[i],
			EYE_WIDTH,EYE_HEIGHT,
			1
		);
		//Right Eye	
		display.drawBitmap(
			RIGHT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
			Bitmap_allEye[i],
			EYE_WIDTH,EYE_HEIGHT,
			1
		);
		//Mouth
		display.drawBitmap(
			MOUTH_DISTANCE_X,
			MOUTH_DISTANCE_Y,
			Bitmap_allMouth[1],
			MOUTH_WIDTH,
			MOUTH_HEIGHT,
			1);
		display.display();
		delay(84);
  }
}

void goSleep(){
	//For eyes closing
  for (int i = 3; i <= 7;i++){
		display.clearDisplay();
  	display.drawBitmap(
			LEFT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
  	Bitmap_allEye[i],
		EYE_WIDTH,
		EYE_HEIGHT,
		1
  );
  //Right Eye
  //display.drawBitmap(EYE_FROM_TOP,RIGHT_EYE_FROM_SIDE,epd_bitmap_allArray[3],EYE_WIDTH,EYE_HEIGHT,1);
  display.drawBitmap(
		RIGHT_EYE_DISTANCE_W,
		EYE_DISTANCE_H,
  	Bitmap_allEye[i],
		EYE_WIDTH,EYE_HEIGHT,
		1
  );
  display.drawBitmap(
		MOUTH_DISTANCE_X,
		MOUTH_DISTANCE_Y,
  	Bitmap_allMouth[1],
		MOUTH_WIDTH,
		MOUTH_HEIGHT,
		1);
  display.display();
  delay(84);
  }
	int waitAnimations = int(random(20,40));
	//Keep eyes closed
	for(int i = 0; i < waitAnimations;i++){
		display.drawBitmap(
			LEFT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
  		Bitmap_allEye[7],
			EYE_WIDTH,
			EYE_HEIGHT,
			1
  	);
  //Right Eye
		display.drawBitmap(
			RIGHT_EYE_DISTANCE_W,
			EYE_DISTANCE_H,
			Bitmap_allEye[7],
			EYE_WIDTH,EYE_HEIGHT,
			1
		);
		display.drawBitmap(
			MOUTH_DISTANCE_X,
			MOUTH_DISTANCE_Y,
			Bitmap_Mouth_1,
			MOUTH_WIDTH,
			MOUTH_HEIGHT,
			1
		);
		//Display Z's
		display.setCursor(100,14);
		display.print("Z");
		display.display();
		delay(1000);
		display.setCursor(110,10);
		display.print("Z");
		display.display();
		delay(1000);
		display.setCursor(122,8);
		display.print("Z");
		display.display();
		delay(1000);
		//Clear Screen
		display.clearDisplay();
	}
	//Show annoyed
	display.clearDisplay();
	//Left Eye
  display.drawBitmap(
		LEFT_EYE_DISTANCE_W,
		EYE_DISTANCE_H,
  	Bitmap_allEye[0],
		EYE_WIDTH,
		EYE_HEIGHT,
		1
  );
  //Right Eye
  //display.drawBitmap(EYE_FROM_TOP,RIGHT_EYE_FROM_SIDE,epd_bitmap_allArray[3],EYE_WIDTH,EYE_HEIGHT,1);
  display.drawBitmap(
		RIGHT_EYE_DISTANCE_W,
		EYE_DISTANCE_H,
  	Bitmap_allEye[3],
		EYE_WIDTH,
		EYE_HEIGHT,
		1
  );
	//Mouth
  display.drawBitmap(
		MOUTH_DISTANCE_X,
		MOUTH_DISTANCE_Y,
		Bitmap_Mouth_2,
		MOUTH_WIDTH,
		MOUTH_HEIGHT,
		1
	);
	delay(500);
}
